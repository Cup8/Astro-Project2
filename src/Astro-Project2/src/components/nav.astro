---
//data imports 
import navData from "../Data/navdata"
---

<nav aria-label="Primary">
  <div class="navbar">
    <a href="/" class="logomark" aria-label="Go Home">
      <img src="/logomark.svg" alt="Logomark" width="40" height="40" />
    </a>
    <ul>
        {
            navData.map((item) => (
                <a href={item.path}>{item.name}</a>
            ))
        }
    </ul>
  </div>
</nav>